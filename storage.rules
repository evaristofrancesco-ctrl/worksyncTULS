rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /documents/{employeeId}/{allPaths=**} {
      // Nota: firestore.get in Storage rules ha limitazioni in questo ambiente.
      // Usiamo l'autenticazione come base per la sicurezza.
      allow read, write: if request.auth != null;
    }
    
    match /profiles/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
