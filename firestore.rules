rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK-SYNC SECURITY RULES - PROTOTYPE VERSION
     * 
     * In questa versione di prototipo, permettiamo l'accesso completo alla società 'default'
     * per facilitare i test con il bypass di login.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role check: Existence of a document in the company's admin role collection
    // Bypass totale per la società 'default' nel prototipo
    function isAdmin(companyId) {
      return companyId == "default" || (isSignedIn() && exists(/databases/$(database)/documents/companies/$(companyId)/roles_admin/$(request.auth.uid)));
    }

    function isManager(companyId) {
      return companyId == "default" || (isSignedIn() && exists(/databases/$(database)/documents/companies/$(companyId)/roles_manager/$(request.auth.uid)));
    }

    function isStaff(companyId) {
      return isAdmin(companyId) || isManager(companyId);
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isExistingStaff(companyId) {
      return resource != null && isStaff(companyId);
    }

    // --- COLLECTION RULES ---

    match /companies/{companyId} {
      allow get, list: if true; // Permettiamo la lettura pubblica per il prototipo
      allow create: if true;
      allow update, delete: if isAdmin(companyId);
    }

    match /companies/{companyId}/locations/{id} {
      allow get, list: if true;
      allow create, update, delete: if companyId == "default" || isStaff(companyId);
    }

    match /companies/{companyId}/departments/{id} {
      allow get, list: if true;
      allow create, update, delete: if companyId == "default" || isStaff(companyId);
    }

    match /companies/{companyId}/shifttemplates/{id} {
      allow get, list: if true;
      allow create, update, delete: if companyId == "default" || isStaff(companyId);
    }

    match /companies/{companyId}/leavetypes/{id} {
      allow get, list: if true;
      allow create, update, delete: if companyId == "default" || isStaff(companyId);
    }

    match /companies/{companyId}/companyholidays/{id} {
      allow get, list: if true;
      allow create, update, delete: if companyId == "default" || isStaff(companyId);
    }

    match /companies/{companyId}/companyannouncements/{id} {
      allow get, list: if true;
      allow create, update, delete: if companyId == "default" || isAdmin(companyId);
    }

    match /companies/{companyId}/roles_admin/{employeeId} {
      allow get, list, create, update, delete: if companyId == "default" || isAdmin(companyId);
    }

    match /companies/{companyId}/roles_manager/{employeeId} {
      allow get, list, create, update, delete: if companyId == "default" || isStaff(companyId);
    }

    match /employees/{employeeId} {
      allow get, list, create, update, delete: if true; // Accesso libero per i dati dipendenti nel prototipo
    }

    match /employees/{employeeId}/shifts/{id} {
      allow get, list, create, update, delete: if true;
    }

    match /employees/{employeeId}/timeentries/{id} {
      allow get, list, create, update, delete: if true;
    }

    match /employees/{employeeId}/leaverequests/{id} {
      allow get, list, create, update, delete: if true;
    }

    match /employees/{employeeId}/documents/{id} {
      allow get, list, create, update, delete: if true;
    }
  }
}