
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * TU.L.S. SECURITY RULES
     * Accesso globale configurato per prototipazione rapida.
     */

    // Regola universale di base
    match /{document=**} {
      allow read, write: if true;
    }

    // Regole esplicite per le collezioni principali per evitare conflitti di gerarchia
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    match /utilities/{utilityId} {
      allow read, write: if true;
    }

    match /employees/{employeeId} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    match /companies/{companyId} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    // Supporto esplicito per query collectionGroup (necessarie per i report admin)
    match /{path=**}/timeentries/{entry} {
      allow read, write: if true;
    }
    
    match /{path=**}/shifts/{shift} {
      allow read, write: if true;
    }

    match /{path=**}/requests/{request} {
      allow read, write: if true;
    }
    
    match /{path=**}/modifications/{mod} {
      allow read, write: if true;
    }
  }
}
