rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK-SYNC SECURITY RULES - PROTOTYPE VERSION
     * 
     * In questa versione di prototipo, permettiamo l'accesso completo a tutti i documenti
     * per facilitare lo sviluppo e i test, incluse le query collectionGroup.
     */

    match /{document=**} {
      allow read, write: if true;
    }

    // Funzioni helper mantenute per riferimento futuro quando verranno ristretti i permessi
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
  }
}