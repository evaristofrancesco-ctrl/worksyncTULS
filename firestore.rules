
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regola base per il prototipo: permette tutto agli utenti autenticati.
    // Questo copre sia le collezioni standard che i collectionGroup (shifts, timeentries, etc.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Permette la lettura degli impiegati anche in fase di login (necessario per check credenziali prima del login completo)
    match /employees/{employeeId} {
      allow read: if true;
    }
  }
}
