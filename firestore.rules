
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * TU.L.S. SECURITY RULES
     * Sblocco totale per prototipazione rapida e supporto Collection Group.
     */

    match /{document=**} {
      allow read, write: if true;
    }

    // Supporto esplicito per query collectionGroup su tutto il database
    match /{path=**}/timeentries/{entry} {
      allow read, write: if true;
    }
    
    match /{path=**}/shifts/{shift} {
      allow read, write: if true;
    }

    match /{path=**}/requests/{request} {
      allow read, write: if true;
    }
  }
}
