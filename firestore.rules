
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONFIGURAZIONE OTTIMIZZATA TU.L.S. (PROTOTIPO)
     * Consente l'accesso completo a tutti gli utenti autenticati.
     * Questo è necessario per supportare le query di ricerca (login) 
     * e i report globali (collectionGroup) su qualsiasi dispositivo.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Permettiamo lettura e scrittura su tutti i documenti se l'utente è autenticato
    // (L'autenticazione anonima viene attivata automaticamente nella pagina di login)
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
