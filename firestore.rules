
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * TU.L.S. SECURITY RULES - ACCESSO UNIVERSALE PROTOTIPO
     * Garantisce che tutte le operazioni di lettura e scrittura siano permesse
     * per evitare blocchi durante lo sviluppo e la prototipazione rapida.
     */

    match /{document=**} {
      allow read, write: if true;
    }

    // Supporto esplicito per le query collectionGroup (Turni, Presenze, Richieste)
    match /{path=**}/timeentries/{entry} {
      allow read, write: if true;
    }
    
    match /{path=**}/shifts/{shift} {
      allow read, write: if true;
    }

    match /{path=**}/requests/{request} {
      allow read, write: if true;
    }
    
    match /{path=**}/modifications/{mod} {
      allow read, write: if true;
    }
  }
}
