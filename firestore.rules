rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK-SYNC SECURITY RULES - PROTOTYPE VERSION
     * 
     * Nota: In questa versione di prototipo, abbiamo allentato le restrizioni per la società 'default'
     * per permettere l'utilizzo del bypass di login "admin/admin".
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role check: Existence of a document in the company's admin role collection
    // O bypass per il prototipo se la società è 'default'
    function isAdmin(companyId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/companies/$(companyId)/roles_admin/$(request.auth.uid)) ||
        (companyId == "default")
      );
    }

    function isManager(companyId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/companies/$(companyId)/roles_manager/$(request.auth.uid)) ||
        (companyId == "default")
      );
    }

    function isStaff(companyId) {
      return isAdmin(companyId) || isManager(companyId);
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isExistingStaff(companyId) {
      return resource != null && isStaff(companyId);
    }

    // --- COLLECTION RULES ---

    match /companies/{companyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(companyId);
    }

    match /companies/{companyId}/locations/{id} {
      allow get, list: if isSignedIn();
      allow create: if isStaff(companyId);
      allow update, delete: if isExistingStaff(companyId);
    }

    match /companies/{companyId}/departments/{id} {
      allow get, list: if isSignedIn();
      allow create: if isStaff(companyId);
      allow update, delete: if isExistingStaff(companyId);
    }

    match /companies/{companyId}/shifttemplates/{id} {
      allow get, list: if isSignedIn();
      allow create: if isStaff(companyId);
      allow update, delete: if isExistingStaff(companyId);
    }

    match /companies/{companyId}/leavetypes/{id} {
      allow get, list: if isSignedIn();
      allow create: if isStaff(companyId);
      allow update, delete: if isExistingStaff(companyId);
    }

    match /companies/{companyId}/companyholidays/{id} {
      allow get, list: if isSignedIn();
      allow create: if isStaff(companyId);
      allow update, delete: if isExistingStaff(companyId);
    }

    match /companies/{companyId}/companyannouncements/{id} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin(companyId);
      allow update, delete: if isAdmin(companyId);
    }

    match /companies/{companyId}/roles_admin/{employeeId} {
      allow get: if isOwner(employeeId) || isAdmin(companyId);
      allow list: if isAdmin(companyId);
      allow create, update, delete: if isAdmin(companyId);
    }

    match /companies/{companyId}/roles_manager/{employeeId} {
      allow get: if isOwner(employeeId) || isStaff(companyId);
      allow list: if isStaff(companyId);
      allow create, update, delete: if isAdmin(companyId);
    }

    match /employees/{employeeId} {
      allow get: if isOwner(employeeId) || isStaff(resource.data.companyId);
      allow list: if isSignedIn();
      allow create: if isOwner(employeeId);
      allow update: if isOwner(employeeId) || isExistingStaff(resource.data.companyId);
      allow delete: if isAdmin(resource.data.companyId) || isExistingOwner(employeeId);
    }

    match /employees/{employeeId}/shifts/{id} {
      allow get, list: if isOwner(employeeId) || isStaff(resource.data.companyId);
      allow create: if isOwner(employeeId) || isStaff(request.resource.data.companyId);
      allow update: if isOwner(employeeId) || isExistingStaff(resource.data.companyId);
      allow delete: if isExistingOwner(employeeId) || isExistingStaff(resource.data.companyId);
    }

    match /employees/{employeeId}/timeentries/{id} {
      allow get, list: if isOwner(employeeId) || isStaff(resource.data.companyId);
      allow create: if isOwner(employeeId);
      allow update: if isOwner(employeeId) || isExistingStaff(resource.data.companyId);
      allow delete: if isExistingOwner(employeeId) || isExistingStaff(resource.data.companyId);
    }

    match /employees/{employeeId}/leaverequests/{id} {
      allow get, list: if isOwner(employeeId) || isStaff(resource.data.companyId);
      allow create: if isOwner(employeeId);
      allow update: if isOwner(employeeId) || isExistingStaff(resource.data.companyId);
      allow delete: if isExistingOwner(employeeId) || isExistingStaff(resource.data.companyId);
    }

    match /employees/{employeeId}/documents/{id} {
      allow get, list: if isOwner(employeeId) || isStaff(resource.data.companyId);
      allow create: if isOwner(employeeId) || isStaff(request.resource.data.companyId);
      allow update: if isOwner(employeeId) || isExistingStaff(resource.data.companyId);
      allow delete: if isExistingOwner(employeeId) || isExistingStaff(resource.data.companyId);
    }
  }
}