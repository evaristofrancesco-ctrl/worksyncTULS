
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK-SYNC SECURITY RULES - PROTOTYPE VERSION
     * Aggiornato il: 2024-05-24T12:00:00Z (Trigger redeploy)
     */

    match /{document=**} {
      allow read, write: if true;
    }

    // Supporto esplicito per query collectionGroup su tutto il database
    match /{path=**}/timeentries/{entry} {
      allow read, write: if true;
    }
  }
}
