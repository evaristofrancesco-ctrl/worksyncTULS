
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regola globale: permette ogni operazione se l'utente è autenticato.
    // Necessaria per supportare query collectionGroup e query su collezioni dinamiche in fase di prototipo.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
