
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permette l'accesso completo a qualsiasi documento se l'utente è autenticato.
    // Questo risolve i problemi con le query collectionGroup e le strutture annidate in fase di prototipo.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
