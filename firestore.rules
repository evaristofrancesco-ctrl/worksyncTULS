
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * TU.L.S. SECURITY RULES
     * Accesso globale configurato per prototipazione rapida.
     * Questo set di regole garantisce che tutte le query (incluso 'list' su /notifications) siano permesse.
     */

    // Regola universale di fallback
    match /{document=**} {
      allow read, write: if true;
    }

    // Permessi espliciti per la collezione notifiche (risolve l'errore 'list' segnalato)
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // Permessi per le altre entità principali
    match /utilities/{utilityId} {
      allow read, write: if true;
    }

    match /employees/{employeeId} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    match /companies/{companyId} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    // Supporto per query collectionGroup su tutto il database
    match /{path=**}/timeentries/{entry} {
      allow read, write: if true;
    }
    
    match /{path=**}/shifts/{shift} {
      allow read, write: if true;
    }

    match /{path=**}/requests/{request} {
      allow read, write: if true;
    }
    
    match /{path=**}/modifications/{mod} {
      allow read, write: if true;
    }
  }
}
